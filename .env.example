# Voice Assistant environment example
# Copy this file to .env and adjust paths for your machine.

# Audio
VA_SAMPLE_RATE=16000
VA_CHUNK_MS=32
VA_VAD_THRESHOLD=0.5
VA_START_CHUNKS=2
VA_END_SILENCE_CHUNKS=20
VA_MIN_SPEECH_SEC=0.3
VA_MAX_UTTERANCE_SEC=20
VA_PRE_SPEECH_SEC=0.4

# Whisper STT (CPU-first default)
VA_WHISPER_MODEL=small
VA_WHISPER_DEVICE=cpu
VA_WHISPER_COMPUTE=int8
# Optional language hint, e.g. en
# VA_WHISPER_LANG=en

# Ollama
VA_OLLAMA_URL=http://localhost:11434/api/generate
VA_OLLAMA_MODEL=tinyllama
VA_OLLAMA_KEEP_ALIVE=30m
VA_OLLAMA_TIMEOUT=90
VA_OLLAMA_SYSTEM_PROMPT=You are a general STEM assistant. Answer science, technology, engineering, and math questions clearly and practically in plain text.

# Gyro-based level switching
# Example endpoint returns JSON with key: gyro_orientation (front/left/right/back)
VA_GYRO_URL=http://10.32.33.98:6000/gpio
VA_GYRO_POLL_INTERVAL=0.1
VA_GYRO_TIMEOUT=1.0

# Piper TTS
# Windows venv example: .venv/Scripts/piper.exe
# macOS/Linux example: .venv/bin/piper
VA_PIPER_BIN=piper
VA_PIPER_MODEL=models/en_US-lessac-medium.onnx
VA_PIPER_CONFIG=models/en_US-lessac-medium.onnx.json

# Raspberry Pi speaker playback server
VA_PI_PLAY_URL=http://jmalpi.local:5000/play
VA_PI_PLAY_TIMEOUT=120
VA_PI_WS_ENABLED=false
VA_PI_WS_URL=ws://jmalpi.local:5001/play
VA_PI_WS_TIMEOUT=15

# Playback backend: sounddevice or ffplay
VA_PLAYBACK_BACKEND=sounddevice
VA_FFPLAY_BIN=ffplay
